/* 加载状态 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 顶部栏 */
.header-bar {
  padding: 10rpx 0 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.settings-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.settings-btn:active {
  background: #f5f5f5;
}

.settings-btn-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.settings-btn-label {
  font-size: 22rpx;
  color: #888;
  font-weight: 500;
}

/* 积分展示卡片 */
.points-card {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  color: #fff;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(46, 125, 50, 0.25);
}

.points-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1.15;
  text-align: center;
  margin: 16rpx 0;
}

.points-unit {
  font-size: 24rpx;
  opacity: 0.7;
  text-align: center;
  margin-bottom: 28rpx;
}

.points-summary {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 14rpx;
  padding: 20rpx 0;
  justify-content: center;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 6rpx;
}

.summary-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
}

/* 分区标题 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 任务网格 */
.task-grid {
  display: flex;
  flex-wrap: wrap;
}

.task-card {
  width: 33.33%;
  box-sizing: border-box;
  padding: 8rpx;
  margin-bottom: 8rpx;
}

.task-card-inner {
  padding: 20rpx 4rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-card-earn .task-card-inner {
  background: #E8F5E9;
}

.task-card-spend .task-card-inner {
  background: #FFF3E0;
}

.task-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.task-name {
  font-size: 26rpx;
  color: #555;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.earn-text {
  color: #A5D6A7;
}

.spend-text {
  color: #FFCC80;
}

/* 欢迎页 */
.welcome-wrap {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0;
}

.welcome-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 60rpx 60rpx;
}

.welcome-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

.welcome-actions {
  padding: 0 32rpx;
}

.welcome-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.welcome-card:active {
  background: #f9f9f9;
}

.welcome-card-icon {
  font-size: 52rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.welcome-card-body {
  flex: 1;
}

.welcome-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.welcome-card-sub {
  font-size: 24rpx;
  color: #aaa;
}

.welcome-card-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.welcome-card-join {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border: none;
}

.welcome-card-join:active {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
}
