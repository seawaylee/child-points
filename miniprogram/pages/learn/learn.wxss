.container {
  padding: 20rpx 32rpx;
}

.header {
  padding: 30rpx 0 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

.category-list {
  display: flex;
  flex-direction: column;
}

.category-card {
  display: flex;
  flex-direction: column;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.category-card:active {
  opacity: 0.85;
}

.category-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.category-icon {
  font-size: 64rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.category-body {
  flex: 1;
}

.category-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}

.category-desc {
  font-size: 24rpx;
  color: #888;
}

.category-arrow {
  font-size: 44rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 进度条 */
.category-progress {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.progress-bar {
  height: 8rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 4rpx;
  position: relative;
  overflow: hidden;
}

.progress-fill {
  position: absolute;
  top: 0;
  height: 100%;
  border-radius: 4rpx;
}

.mastered-fill {
  background: #4CAF50;
  left: 0;
}

.learning-fill {
  background: #2196F3;
}

.progress-text {
  font-size: 22rpx;
  color: #888;
  margin-top: 8rpx;
}
