<view class="container" wx:if="{{!loading}}">
  <!-- 任务信息 -->
  <view class="task-header card flex-row">
    <view class="task-type-badge {{task.type === 'earn' ? 'badge-earn' : 'badge-spend'}}">
      {{task.type === 'earn' ? '📖' : '🎮'}}
    </view>
    <view class="task-header-info flex-1">
      <view class="task-header-name">{{task.name}}</view>
      <view class="task-header-meta">
        <text class="{{task.type === 'earn' ? 'tag-earn' : 'tag-spend'}}">
          {{task.type === 'earn' ? '赚积分' : '花积分'}}
        </text>
        <text class="task-ppm" wx:if="{{task.taskMode === 'count'}}">{{task.pointsPerCount || 1}}分/次</text>
        <text class="task-ppm" wx:elif="{{task.pointsPerMinute}}">{{task.pointsPerMinute}}分/分钟</text>
      </view>
    </view>
  </view>

  <!-- 时长选择（时长类） -->
  <view class="section" wx:if="{{task.taskMode !== 'count'}}">
    <view class="section-label">选择时长（分钟）</view>
    <view class="duration-grid">
      <view
        class="duration-btn {{selectedDuration === item ? 'duration-active' : ''}}"
        wx:for="{{durationPresets}}"
        wx:key="*this"
        data-duration="{{item}}"
        bindtap="onDurationTap"
      >
        {{item}}分钟
      </view>
      <view
        class="duration-btn {{showCustomInput ? 'duration-active' : ''}}"
        bindtap="onCustomDurationToggle"
      >
        自定义
      </view>
    </view>
    <!-- 自定义输入 -->
    <view class="custom-input-wrap" wx:if="{{showCustomInput}}">
      <input
        class="custom-input"
        type="number"
        placeholder="输入分钟数"
        value="{{customDuration}}"
        bindinput="onCustomDurationInput"
      />
    </view>
    <!-- 已选时长提示 -->
    <view class="duration-result" wx:if="{{selectedDuration > 0}}">
      <text class="duration-result-text">
        已选 {{selectedDuration}} 分钟 = {{pointsPreview}} 积分
      </text>
    </view>
  </view>

  <!-- 次数选择（次数类） -->
  <view class="section" wx:if="{{task.taskMode === 'count'}}">
    <view class="section-label">选择次数</view>
    <view class="duration-grid">
      <view
        class="duration-btn {{selectedCount === item ? 'duration-active' : ''}}"
        wx:for="{{countPresets}}"
        wx:key="*this"
        data-count="{{item}}"
        bindtap="onCountTap"
      >
        {{item}}次
      </view>
      <view
        class="duration-btn {{showCustomCountInput ? 'duration-active' : ''}}"
        bindtap="onCustomCountToggle"
      >
        自定义
      </view>
    </view>
    <!-- 自定义输入 -->
    <view class="custom-input-wrap" wx:if="{{showCustomCountInput}}">
      <input
        class="custom-input"
        type="number"
        placeholder="输入次数"
        value="{{customCount}}"
        bindinput="onCustomCountInput"
      />
    </view>
    <!-- 已选次数提示 -->
    <view class="duration-result" wx:if="{{selectedCount > 0}}">
      <text class="duration-result-text">
        已选 {{selectedCount}} 次 = {{pointsPreview}} 积分
      </text>
    </view>
  </view>

  <!-- 照片 -->
  <view class="section">
    <view class="section-label">拍照记录（可选）</view>
    <view class="photo-area">
      <view class="photo-preview" wx:if="{{photoPath}}">
        <image class="photo-image" src="{{photoPath}}" mode="aspectFill" bindtap="onPreviewPhoto" />
        <view class="photo-remove" bindtap="onRemovePhoto">✕</view>
      </view>
      <view class="photo-add" wx:else bindtap="onTakePhoto">
        <view class="photo-add-icon">📷</view>
        <view class="photo-add-text">拍照/选择照片</view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <view class="section-label">备注（可选）</view>
    <view class="note-input-wrap">
      <textarea
        class="note-input"
        placeholder="写点什么..."
        maxlength="200"
        value="{{note}}"
        bindinput="onNoteInput"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <view
      class="submit-btn {{submitting ? 'submit-btn-disabled' : ''}} {{task.type === 'earn' ? 'submit-earn' : 'submit-spend'}}"
      bindtap="onSubmit"
    >
      {{submitting ? '提交中...' : '确认记录'}}
    </view>
  </view>
</view>
