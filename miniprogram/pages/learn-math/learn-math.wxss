.container {
  padding: 20rpx 32rpx;
  padding-bottom: 160rpx;
}

/* 设置栏 */
.setting-bar {
  display: flex;
  flex-direction: row;
  padding: 16rpx 0 24rpx;
}

.setting-picker {
  margin-right: 20rpx;
}

.setting-btn {
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #555;
}

.setting-btn:active {
  background: #e8e8e8;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 成绩卡片 */
.score-card {
  text-align: center;
  padding: 40rpx;
  margin-bottom: 24rpx;
}

.score-value {
  font-size: 64rpx;
  font-weight: 800;
  color: #333;
}

.score-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.score-rate {
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

/* 题目列表 */
.problem-list {
  margin-top: 10rpx;
}

.problem-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.problem-item.item-correct {
  border-left: 6rpx solid #4CAF50;
}

.problem-item.item-wrong {
  border-left: 6rpx solid #F44336;
}

.problem-expr {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.problem-input {
  width: 120rpx;
  height: 60rpx;
  text-align: center;
  font-size: 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  margin: 0 16rpx;
}

.problem-answer {
  font-size: 26rpx;
  color: #F44336;
  font-weight: 600;
  margin-right: 12rpx;
}

.problem-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.btn-submit {
  background: linear-gradient(135deg, #2196F3 0%, #1565C0 100%);
  box-shadow: 0 6rpx 16rpx rgba(33, 150, 243, 0.3);
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-retry {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  box-shadow: 0 6rpx 16rpx rgba(76, 175, 80, 0.3);
}

.btn-retry:active {
  opacity: 0.85;
}
