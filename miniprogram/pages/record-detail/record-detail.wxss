/* 任务头部 */
.task-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 30rpx;
}

.task-type-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.badge-earn {
  background-color: #E8F5E9;
}

.badge-spend {
  background-color: #FFF3E0;
}

.task-header-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.task-header-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-ppm {
  font-size: 24rpx;
  color: #aaa;
}

/* 区域 */
.section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 时长选择 */
.duration-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.duration-btn {
  min-width: 140rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background-color: #f7f8fa;
  font-size: 28rpx;
  color: #555;
  border: 2rpx solid transparent;
  font-weight: 500;
}

.duration-active {
  background-color: #E8F5E9;
  color: #43A047;
  border-color: #4CAF50;
  font-weight: 700;
}

.custom-input-wrap {
  margin-top: 20rpx;
}

.custom-input {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  border: 2rpx solid #4CAF50;
}

.duration-result {
  margin-top: 20rpx;
  padding: 18rpx 24rpx;
  background-color: #FFF3E0;
  border-radius: 14rpx;
}

.duration-result-text {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 500;
}

/* 照片区域 */
.photo-area {
  margin-top: 10rpx;
}

.photo-preview {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

.photo-add {
  width: 240rpx;
  height: 240rpx;
  border: 2rpx dashed #ddd;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.photo-add-icon {
  font-size: 56rpx;
  margin-bottom: 10rpx;
}

.photo-add-text {
  font-size: 24rpx;
  color: #bbb;
}

/* 备注 */
.note-input-wrap {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 4rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  padding: 22rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-area {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

.submit-earn {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.25);
}

.submit-spend {
  background: linear-gradient(135deg, #FF7043 0%, #E64A19 100%);
  box-shadow: 0 8rpx 24rpx rgba(255, 112, 67, 0.25);
}

.submit-btn-disabled {
  opacity: 0.5;
}
