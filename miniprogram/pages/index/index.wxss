/* 加载状态 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 顶部栏 */
.header-bar {
  padding: 10rpx 0 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  font-size: 36rpx;
}

/* 积分展示卡片 */
.points-card {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  color: #fff;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 32rpx rgba(46, 125, 50, 0.25);
}

.points-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1.15;
  text-align: center;
  margin: 16rpx 0;
}

.points-unit {
  font-size: 24rpx;
  opacity: 0.7;
  text-align: center;
  margin-bottom: 28rpx;
}

.points-summary {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 14rpx;
  padding: 20rpx 0;
  justify-content: center;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 6rpx;
}

.summary-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.25);
}

/* 分区标题 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 任务网格 */
.task-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -8rpx;
}

.task-card {
  width: calc(25% - 16rpx);
  margin: 0 8rpx 16rpx;
  padding: 24rpx 8rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-card-earn {
  background: #E8F5E9;
}

.task-card-spend {
  background: #FFF3E0;
}

.task-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.task-name {
  font-size: 22rpx;
  color: #555;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.earn-text {
  color: #A5D6A7;
}

.spend-text {
  color: #FFCC80;
}
