.task-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.task-btn__icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 10rpx;
}

.task-btn__name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  line-height: 1.3;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.task-btn__tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid;
  line-height: 1.4;
}

/* Compact mode */
.task-btn--compact {
  flex-direction: row;
  width: auto;
  padding: 10rpx 16rpx;
  border-radius: 10rpx;
  gap: 10rpx;
}

.task-btn--compact .task-btn__icon {
  font-size: 32rpx;
  margin-bottom: 0;
}

.task-btn--compact .task-btn__name {
  font-size: 22rpx;
  margin-bottom: 0;
  max-width: 120rpx;
}

.task-btn--compact .task-btn__tag {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
}