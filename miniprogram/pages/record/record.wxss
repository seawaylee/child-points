/* 分区 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-earn {
  background-color: #4CAF50;
}

.dot-spend {
  background-color: #ff5252;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 任务项 */
.task-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 24rpx;
}

.task-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.task-icon-earn {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}

.task-icon-spend {
  background: linear-gradient(135deg, #FFEBEE, #FFCDD2);
}

.task-icon-text {
  font-size: 40rpx;
}

.task-info {
  overflow: hidden;
}

.task-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-ppm {
  font-size: 22rpx;
  color: #999;
}

.task-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 16rpx;
  flex-shrink: 0;
}
