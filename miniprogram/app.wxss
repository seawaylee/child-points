page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  color: #333;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 140rpx;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #43A047 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.25);
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.25);
}

.btn-danger {
  background: #fff;
  color: #ff5252;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 22rpx 0;
  text-align: center;
  border: 2rpx solid #ffcdd2;
}

.btn-danger::after {
  border: none;
}

/* 卡片 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 标签 */
.tag-earn {
  background-color: #E8F5E9;
  color: #43A047;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag-spend {
  background-color: #FFF3E0;
  color: #E65100;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  color: #aaa;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

/* flex 工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}
