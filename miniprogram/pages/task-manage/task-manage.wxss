/* 区域标题 */
.section {
  margin-bottom: 30rpx;
}

.section-title-bar {
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-earn {
  background-color: #4CAF50;
}

.dot-spend {
  background-color: #FF7043;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 任务滑动包裹 */
.task-swipe-wrap {
  overflow: hidden;
  position: relative;
  margin-bottom: 12rpx;
}

.task-swipe-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #ff5252;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 20rpx 20rpx 0;
}

.swipe-action-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.task-swipe-content {
  position: relative;
  z-index: 1;
  transition: transform 0.2s ease;
}

.task-swipe-content.swiped {
  transform: translateX(-140rpx);
}

.task-manage-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 0;
}

/* 拖拽手柄 */
.drag-handle {
  font-size: 28rpx;
  color: #ccc;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1;
}

/* 拖拽中的项 */
.dragging-item {
  opacity: 0.85;
  transform: scale(1.02);
  z-index: 10;
}

.dragging-item .task-manage-item {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 任务项 */
.task-item-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.icon-earn-wrap {
  background-color: #E8F5E9;
}

.icon-spend-wrap {
  background-color: #FFF3E0;
}

.task-item-info {
  overflow: hidden;
}

.task-item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.task-item-meta {
  gap: 12rpx;
}

.task-item-ppm {
  font-size: 22rpx;
  color: #aaa;
}

/* 开关 */
.task-toggle {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 10rpx;
}

.toggle-on {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: #4CAF50;
  position: relative;
}

.toggle-on::after {
  content: '';
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  right: 4rpx;
  top: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.toggle-off {
  width: 80rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: #ddd;
  position: relative;
}

.toggle-off::after {
  content: '';
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #fff;
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

/* 添加按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 10;
}

.add-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 28rpx rgba(76, 175, 80, 0.3);
}

.add-btn-icon {
  font-size: 40rpx;
  font-weight: 300;
}

.add-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 44rpx;
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.15);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 36rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-control {
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 22rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

/* 类型选择器 */
.type-selector {
  gap: 20rpx;
}

.type-option {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 24rpx;
  border-radius: 14rpx;
  background: #f7f8fa;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.type-selected.type-earn {
  background: #E8F5E9;
  border-color: #4CAF50;
}

.type-selected.type-spend {
  background: #FFF3E0;
  border-color: #FF7043;
}

/* 自定义单选按钮 */
.custom-radio {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  position: relative;
}

.radio-earn {
  border-color: #4CAF50;
}

.radio-earn::after {
  content: '';
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #4CAF50;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.radio-spend {
  border-color: #FF7043;
}

.radio-spend::after {
  content: '';
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #FF7043;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* 表单按钮 */
.form-actions {
  margin-top: 40rpx;
  gap: 16rpx;
}

.form-btn {
  text-align: center;
  padding: 22rpx 0;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.form-btn-cancel {
  background: #f5f5f5;
  color: #888;
}

.form-btn-submit {
  background: linear-gradient(135deg, #4CAF50 0%, #43A047 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}
