/* 表单模式 */
.form-card {
  padding: 48rpx 40rpx;
}

.form-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 48rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
}

.invite-code-input {
  text-align: center;
  font-size: 44rpx;
  letter-spacing: 20rpx;
  font-weight: bold;
  color: #1976D2;
}

.form-hint {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  margin-top: 12rpx;
}

/* 卡片区域标题 */
.card-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* 信息行 */
.info-row {
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 8rpx;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.info-edit {
  font-size: 24rpx;
}

/* 编辑行 */
.edit-row {
  padding: 12rpx 0;
}

.edit-group {
  gap: 12rpx;
  margin-top: 8rpx;
}

.edit-input {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  border: 2rpx solid #4CAF50;
}

.edit-btn {
  padding: 14rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.edit-btn-save {
  background-color: #4CAF50;
  color: #fff;
}

.edit-btn-cancel {
  background-color: #f5f5f5;
  color: #888;
}

/* 邀请码 */
.invite-card {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border: none;
}

.invite-code-box {
  background: rgba(255, 255, 255, 0.8);
  border-radius: 16rpx;
  padding: 32rpx;
  justify-content: center;
  gap: 24rpx;
}

.invite-code {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 18rpx;
  color: #1565C0;
}

.copy-btn {
  background: #1565C0;
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.invite-hint {
  font-size: 24rpx;
  color: #1565C0;
  text-align: center;
  margin-top: 16rpx;
  opacity: 0.7;
}

/* 成员列表 */
.member-list {
  margin-top: 10rpx;
}

.member-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-item-tap {
  padding-right: 8rpx;
}

.member-item-tap:active {
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.member-role-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 8rpx;
  font-weight: 300;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  font-size: 30rpx;
  color: #43A047;
  font-weight: 700;
}

.member-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.member-role {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.role-admin {
  background-color: #FFF3E0;
  color: #E65100;
}

.role-member {
  background-color: #f5f5f5;
  color: #999;
}

.empty-hint {
  font-size: 26rpx;
  color: #aaa;
  text-align: center;
  padding: 20rpx 0;
}

/* 任务管理入口 */
.manage-entry {
  padding: 28rpx 32rpx;
}

.manage-entry-content {
  width: 100%;
}

.manage-entry-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.manage-entry-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
}

.manage-entry-sub {
  font-size: 24rpx;
  color: #aaa;
}

.manage-entry-arrow {
  font-size: 44rpx;
  color: #ccc;
  font-weight: 300;
}

/* 退出按钮 */
.leave-btn {
  margin-top: 48rpx;
  font-size: 28rpx;
  padding: 24rpx 0;
}

/* 月度赠送提示 */
.allowance-hint {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 12rpx;
}
